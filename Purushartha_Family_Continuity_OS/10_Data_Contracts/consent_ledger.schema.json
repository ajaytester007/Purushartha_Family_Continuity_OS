{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConsentLedger",
  "type": "object",
  "required": [
    "record_id",
    "owner",
    "purpose",
    "allowed_viewers",
    "status"
  ],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "allowed_analyses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_viewers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retention_until": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "active",
        "revoked",
        "expired",
        "restricted"
      ]
    }
  }
}
