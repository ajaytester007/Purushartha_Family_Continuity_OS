{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PersonStateSCD2",
  "type": "object",
  "required": [
    "person_id",
    "valid_from",
    "is_current"
  ],
  "properties": {
    "person_id": {
      "type": "string"
    },
    "valid_from": {
      "type": "string",
      "format": "date-time"
    },
    "valid_to": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "is_current": {
      "type": "boolean"
    },
    "state": {
      "type": "object"
    },
    "source_event_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
